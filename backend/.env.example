# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# PostgreSQL — change POSTGRES_HOST / POSTGRES_PORT for your setup
# Local Docker (default): localhost:5432
# Multiple PG versions on Windows: check postgresql.conf (e.g. PG18 often uses 5434)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_news_analyzer

# Optional: set full URL instead of POSTGRES_* (ensure-env builds this if omitted)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_news_analyzer?schema=public

# Redis — change REDIS_HOST when Redis runs elsewhere
# Local Docker: localhost | Backend in same compose network: redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: set full URL instead of REDIS_* (ensure-env builds this if omitted)
# REDIS_URL=redis://localhost:6379

# OpenAI (Step 10 — AI analysis)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# News collector (legacy pipeline — existing app)
NEWS_POLL_INTERVAL_SECONDS=30
NEWS_PROVIDERS=nse,mock
ENABLE_MOCK_NEWS=true

# News Ingestion Engine (new module)
NEWS_INGESTION_ENABLED=true
NEWS_POLL_INTERVAL_MS=30000
NEWS_INGESTION_PROVIDERS=nse,bse
NEWS_MAX_RETRIES=3
NEWS_RETRY_BASE_MS=1000
NEWS_RETRY_MAX_MS=30000
NEWS_FINGERPRINT_CACHE_TTL_SECONDS=2592000
NEWS_SCHEDULER_LOG_LEVEL=info
NEWS_SCHEDULER_LOG_FILE=logs/ingestion-scheduler.log
NEWS_LOG_PROVIDER_TIMING=true

# NSE provider
NSE_BASE_URL=https://www.nseindia.com
NSE_HOMEPAGE_URL=https://www.nseindia.com
NSE_ANNOUNCEMENTS_PATH=/api/corporate-announcements
NSE_INDEX=equities
NSE_DATE_RANGE_DAYS=1
NSE_TIMEOUT_MS=15000
NSE_MAX_RETRIES=3
NSE_COOKIE_STRATEGY=on-auth-failure

# BSE provider
BSE_BASE_URL=https://api.bseindia.com
BSE_ANNOUNCEMENTS_PATH=/BseIndiaAPI/api/CorpAnn/w
BSE_DATE_RANGE_DAYS=1
BSE_MAX_PAGES=20
BSE_TIMEOUT_MS=15000
BSE_MAX_RETRIES=3

# CORS — frontend origin for Socket.io + REST
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
