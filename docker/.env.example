# Docker Compose environment — copy to docker/.env before running
#
# cp docker/.env.example docker/.env

# --- Infrastructure ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_news_analyzer
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- Ports (host machine) ---
BACKEND_PORT=4000
FRONTEND_PORT=3000

# --- Backend ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
NEWS_POLL_INTERVAL_SECONDS=30
NEWS_PROVIDERS=nse,mock
ENABLE_MOCK_NEWS=true
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
SEED_ON_START=true

# --- Frontend (baked in at build time) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Hostnames when connecting from your machine (not from inside Docker):
POSTGRES_HOST=localhost
REDIS_HOST=localhost
